<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="SegmentedButton">
        <attr name="android:background" />
        <attr name="android:fontFamily" format="string" />
        <attr name="android:ellipsize">
            <enum name="none" value="0" />
            <enum name="start" value="1" />
            <enum name="middle" value="2" />
            <enum name="end" value="3" />
            <enum name="marquee" value="4" />
        </attr>

        <attr name="segmentedButton_selectedBackground" format="reference|color" />
        <attr name="segmentedButton_rippleColor" format="color" />
        <attr name="segmentedButton_rounded" format="boolean" />
        <attr name="segmentedButton_drawable" format="reference" />
        <attr name="segmentedButton_drawablePadding" format="dimension" />
        <attr name="segmentedButton_drawableTint" format="color" />
        <attr name="segmentedButton_selectedDrawableTint" format="color" />
        <attr name="segmentedButton_drawableWidth" format="dimension" />
        <attr name="segmentedButton_drawableHeight" format="dimension" />
        <attr name="segmentedButton_drawableGravity" format="integer">
            <flag name="top" value="0x30" />
            <flag name="bottom" value="0x50" />
            <flag name="left" value="0x03" />
            <flag name="right" value="0x05" />
        </attr>

        <attr name="segmentedButton_text" format="string" />
        <attr name="segmentedButton_textColor" format="color" />
        <attr name="segmentedButton_selectedTextColor" format="color" />
        <attr name="segmentedButton_textSize" format="dimension" />
        <attr name="segmentedButton_linesCount" format="integer" />
        <attr name="segmentedButton_textStyle" format="integer">
            <flag name="normal" value="0" />
            <flag name="bold" value="1" />
            <flag name="italic" value="2" />
        </attr>
        <attr name="segmentedButton_selectedTextStyle" format="integer">
            <flag name="normal" value="0" />
            <flag name="bold" value="1" />
            <flag name="italic" value="2" />
        </attr>
    </declare-styleable>

    <declare-styleable name="SegmentedButtonGroup">
        <attr name="android:background" />
        <attr name="android:clickable" />

        <attr name="segmentedButtonGroup_borderWidth" format="dimension" />
        <attr name="segmentedButtonGroup_borderColor" format="color" />
        <attr name="segmentedButtonGroup_borderDashWidth" format="dimension" />
        <attr name="segmentedButtonGroup_borderDashGap" format="dimension" />

        <attr name="segmentedButtonGroup_selectedBackground" format="reference|color" />
        <attr name="segmentedButtonGroup_selectedBorderWidth" format="dimension" />
        <attr name="segmentedButtonGroup_selectedBorderColor" format="color" />
        <attr name="segmentedButtonGroup_selectedBorderDashWidth" format="dimension" />
        <attr name="segmentedButtonGroup_selectedBorderDashGap" format="dimension" />

        <attr name="segmentedButtonGroup_radius" format="dimension" />
        <attr name="segmentedButtonGroup_selectedButtonRadius" format="dimension" />
        <attr name="segmentedButtonGroup_position" format="integer" />
        <attr name="segmentedButtonGroup_draggable" format="boolean" />
        <attr name="segmentedButtonGroup_ripple" format="boolean" />
        <attr name="segmentedButtonGroup_rippleColor" format="color" />

        <attr name="segmentedButtonGroup_divider" format="reference" />
        <attr name="segmentedButtonGroup_dividerWidth" format="dimension" />
        <attr name="segmentedButtonGroup_dividerRadius" format="dimension" />
        <attr name="segmentedButtonGroup_dividerPadding" format="dimension" />

        <attr name="segmentedButtonGroup_selectionAnimationDuration" format="integer" />
        <attr name="segmentedButtonGroup_selectionAnimationInterpolator" format="enum">
            <enum name="none" value="-1" />
            <enum name="fastOutSlowIn" value="0" />
            <enum name="bounce" value="1" />
            <enum name="linear" value="2" />
            <enum name="decelerate" value="3" />
            <enum name="cycle" value="4" />
            <enum name="anticipate" value="5" />
            <enum name="accelerateDecelerate" value="6" />
            <enum name="accelerate" value="7" />
            <enum name="anticipateOvershoot" value="8" />
            <enum name="fastOutLinearIn" value="9" />
            <enum name="linearOutSlowIn" value="10" />
            <enum name="overshoot" value="11" />
        </attr>
    </declare-styleable>
</resources>
